#!/bin/bash
# kavex — Kavex Protocol CLI
# Zero-token commands for help, status, activate, deactivate, install.
# For LLM-powered commands, use Claude Code slash commands: /kavex:loop, /kavex:init
#
# Usage:
#   kavex help
#   kavex status
#   kavex activate
#   kavex deactivate
#   kavex install [--dry-run]

set -e

# Colors (disable if not a terminal)
if [ -t 1 ]; then
  BOLD='\033[1m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  RED='\033[0;31m'
  CYAN='\033[0;36m'
  DIM='\033[0;2m'
  RESET='\033[0m'
else
  BOLD='' GREEN='' YELLOW='' RED='' CYAN='' DIM='' RESET=''
fi

# Find project root (walk up until .claude/ or .git found)
find_project_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.claude" ] || [ -d "$dir/.git" ]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}

PROJECT_ROOT="$(find_project_root)"
SETTINGS_LOCAL="$PROJECT_ROOT/.claude/settings.local.json"
SETTINGS="$PROJECT_ROOT/.claude/settings.json"

# Resolve kavex root: use CLAUDE_PLUGIN_ROOT if available, else script's parent
KAVEX_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

KAVEX_HOOK_FILES=(
  format.sh
  verify-on-stop.sh
  block-dangerous.sh
  protect-files.sh
  kavex-loop.sh
  kavex-commit-gate.sh
)

KAVEX_LIB_FILES=(
  detect-stack.sh
  parse-prd.sh
  verify-gate.sh
  parse-failures.sh
  generate-prompt.sh
  run-code-review.sh
  rate-limiter.sh
  circuit-breaker.sh
  codex-assist.sh
  kavex-statusline.sh
  kavex-snapshot.sh
  kavex-verify.sh
  kavex-safe-commit.sh
  kavex-cleanup.sh
  kavex-config.sh
)

readonly KAVEX_HOOK_COMMANDS_JSON='[
  "cat | .claude/hooks/block-dangerous.sh",
  "cat | .claude/hooks/kavex-commit-gate.sh",
  "cat | .claude/hooks/protect-files.sh",
  "cat | .claude/hooks/format.sh",
  "cat | .claude/hooks/verify-on-stop.sh"
]'

remove_kavex_hooks_from_settings_file() {
  local file="$1"
  local current updated

  current="$(cat "$file")"
  updated="$(jq --argjson kavex_commands "$KAVEX_HOOK_COMMANDS_JSON" '
    def strip_kavex_hooks($kavex_commands):
      if (.hooks | type?) != "object" then
        .
      else
        .hooks |= with_entries(
          .value |= (
            if type == "array" then
              map(
                if (.hooks | type?) == "array" then
                  .hooks |= map(
                    select(
                      (.command? // "") as $cmd
                      | ($kavex_commands | index($cmd)) == null
                    )
                  )
                  | select((.hooks | length) > 0)
                else
                  .
                end
              )
            else
              .
            end
          )
          | select((.value | type) != "array" or (.value | length) > 0)
        )
        | if (.hooks | length) == 0 then del(.hooks) else . end
      end;
    strip_kavex_hooks($kavex_commands)
  ' "$file")" || return 1

  if [ "$updated" != "$current" ]; then
    printf '%s\n' "$updated" > "$file"
    return 0
  fi

  return 1
}

is_kavex_managed_settings_file() {
  local file="$1"

  jq --argjson kavex_commands "$KAVEX_HOOK_COMMANDS_JSON" '
    def hook_commands:
      [.hooks[]?[]? | .hooks[]?.command?];

    ([keys_unsorted[]] - ["hooks", "permissions"] | length) == 0
    and (hook_commands | length) > 0
    and all(hook_commands[]; $kavex_commands | index(.) != null)
  ' "$file" 2>/dev/null
}

# ─────────────────────────────────────────────
# kavex help
# ─────────────────────────────────────────────
cmd_help() {
  cat <<'HELP'
═══════════════════════════════════════════════
 KAVEX PROTOCOL — Quick Reference
═══════════════════════════════════════════════

 What is Kavex?
 An automation layer that gives Claude safety hooks,
 verification gates, workflow commands, and auto-formatting.

 CLI COMMANDS (zero tokens)
 ─────────────────────────────────────────────
  kavex help          This help page
  kavex status        Check hooks, stack, commands
  kavex activate      Turn ON all automatic hooks
  kavex deactivate    Turn OFF all automatic hooks
  kavex install       Install Kavex into current project
  kavex uninstall     Remove Kavex from current project
  kavex setup         Interactive setup wizard
  kavex monitor       tmux dashboard (delegates to kavex-monitor)
  kavex config        Manage configuration
  kavex config --dangerously-skip-safety [on|off]
                      Disable/enable safety hooks (like claude --dangerously-skip-permissions)

 SLASH COMMANDS (use inside Claude Code)
 ─────────────────────────────────────────────
  Workflow:
    /plan [feature]    Plan before coding, wait for "go"
    /commit-push-pr    Stage, commit, push, open draft PR
    /verify-app        Full 10-layer QA sweep
    /fix-and-verify    Autonomous bug fixing loop
    /code-review       4 parallel reviewers + optional Codex
    /simplify          Clean up code, keep behaviour
    /daily-standup     Engineering report

  Kavex (LLM-powered):
    /kavex:init [name]  Scaffold a new PRD file
    /kavex:loop <prd>   Team Loop: 6-phase cycle per item

  Reference (load on demand):
    /core-rules        /typescript-rules   /error-handling
    /security-rules    /code-cleanup       /style-guide
    /troubleshooting   /techdebt           /worktree-workflow
    /framework-rules

 HOOKS (automatic when activated)
 ─────────────────────────────────────────────
  format.sh           Format on every file write
  block-dangerous.sh  Block rm -rf, force push, DROP TABLE
  protect-files.sh    Block edits to .env, .pem, secrets
  verify-on-stop.sh      7-layer gate when Claude finishes
  kavex-commit-gate.sh    Block commits without verification
  kavex-loop.sh           Team Loop orchestration

 SUPPORTED LANGUAGES
 ─────────────────────────────────────────────
  Node.js · Python · Go · Rust · Ruby · Java · .NET
  (auto-detected from lockfiles and config files)

═══════════════════════════════════════════════
HELP
}

# ─────────────────────────────────────────────
# kavex status
# ─────────────────────────────────────────────
cmd_status() {
  echo ""
  echo -e "${BOLD}KAVEX STATUS${RESET}"
  echo "═══════════════════════════════════════"

  # Detect stack
  local stack=""
  local pm="N/A"

  if [ -f "$PROJECT_ROOT/package.json" ]; then
    if [ -f "$PROJECT_ROOT/pnpm-lock.yaml" ]; then pm="pnpm"
    elif [ -f "$PROJECT_ROOT/yarn.lock" ]; then pm="yarn"
    elif [ -f "$PROJECT_ROOT/bun.lockb" ]; then pm="bun"
    else pm="npm"
    fi
    stack="${stack}Node.js ($pm), "
  fi
  [ -f "$PROJECT_ROOT/pyproject.toml" ] || [ -f "$PROJECT_ROOT/requirements.txt" ] && stack="${stack}Python, "
  [ -f "$PROJECT_ROOT/go.mod" ] && stack="${stack}Go, "
  [ -f "$PROJECT_ROOT/Cargo.toml" ] && stack="${stack}Rust, "
  [ -f "$PROJECT_ROOT/Gemfile" ] && stack="${stack}Ruby, "
  [ -f "$PROJECT_ROOT/pom.xml" ] || [ -f "$PROJECT_ROOT/build.gradle" ] && stack="${stack}Java, "
  ls "$PROJECT_ROOT"/*.csproj &>/dev/null 2>&1 || ls "$PROJECT_ROOT"/*.sln &>/dev/null 2>&1 && stack="${stack}.NET, "

  stack="${stack%, }"
  [ -z "$stack" ] && stack="none detected"

  echo -e "  Stack:           ${GREEN}${stack}${RESET}"
  echo -e "  Package manager: ${CYAN}${pm}${RESET}"

  # Check hooks
  local hooks_active=0
  local settings_file=""

  if [ -f "$SETTINGS_LOCAL" ]; then
    settings_file="$SETTINGS_LOCAL"
  elif [ -f "$SETTINGS" ]; then
    settings_file="$SETTINGS"
  fi

  if [ -n "$settings_file" ] && command -v jq &>/dev/null; then
    local has_hooks
    has_hooks=$(jq 'has("hooks")' "$settings_file" 2>/dev/null || echo "false")
    if [ "$has_hooks" = "true" ]; then
      # Count hook arrays that exist
      for event in PreToolUse PostToolUse Stop SessionStart; do
        local count
        count=$(jq ".hooks.${event} | length // 0" "$settings_file" 2>/dev/null || echo "0")
        if [ "$count" != "0" ] && [ "$count" != "null" ]; then
          hooks_active=$((hooks_active + count))
        fi
      done
    fi
  fi

  if [ "$hooks_active" -gt 0 ]; then
    echo -e "  Hooks:           ${GREEN}${hooks_active} configured${RESET}"
  else
    echo -e "  Hooks:           ${YELLOW}none active${RESET} (run: kavex activate)"
  fi

  # Check hook scripts exist in the project (legacy install path or plugin root)
  local missing_hooks=0
  for hook in format.sh block-dangerous.sh protect-files.sh verify-on-stop.sh kavex-loop.sh kavex-commit-gate.sh; do
    if [ ! -f "$PROJECT_ROOT/.claude/hooks/$hook" ] && [ ! -f "$PROJECT_ROOT/hooks/$hook" ]; then
      missing_hooks=$((missing_hooks + 1))
    fi
  done

  if [ "$missing_hooks" -gt 0 ]; then
    echo -e "  Hook scripts:    ${RED}${missing_hooks} missing${RESET} (run: kavex install)"
  else
    echo -e "  Hook scripts:    ${GREEN}all present${RESET}"
  fi

  # Check commands in the project (legacy or plugin root)
  local cmd_count=0
  if [ -d "$PROJECT_ROOT/commands" ]; then
    cmd_count=$(find "$PROJECT_ROOT/commands" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  elif [ -d "$PROJECT_ROOT/.claude/commands" ]; then
    cmd_count=$(find "$PROJECT_ROOT/.claude/commands" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  fi
  echo -e "  Commands:        ${CYAN}${cmd_count} available${RESET}"

  # Check shared lib in the project
  if [ -f "$PROJECT_ROOT/hooks/lib/detect-stack.sh" ] || [ -f "$PROJECT_ROOT/.claude/hooks/lib/detect-stack.sh" ]; then
    echo -e "  Shared library:  ${GREEN}OK${RESET}"
  else
    echo -e "  Shared library:  ${RED}MISSING${RESET}"
  fi

  # Check Team Loop in the project
  if [ -f "$PROJECT_ROOT/commands/kavex/loop.md" ] || [ -f "$PROJECT_ROOT/.claude/commands/kavex/loop.md" ]; then
    echo -e "  Team Loop:       ${GREEN}available${RESET}"
  else
    echo -e "  Team Loop:       ${YELLOW}not installed${RESET}"
  fi

  # Check active loop
  if [ -d "$PROJECT_ROOT/.kavex-loop" ]; then
    echo -e "  Active loop:     ${YELLOW}in progress${RESET} (.kavex-loop/ exists)"
  fi

  # Check Codex
  if command -v codex &>/dev/null; then
    echo -e "  Codex CLI:       ${GREEN}installed${RESET} (multi-model review enabled)"
  else
    echo -e "  Codex CLI:       ${DIM}not installed (optional)${RESET}"
  fi

  # Check safety skip status
  local config_file="${XDG_CONFIG_HOME:-$HOME/.config}/kavex/config.json"
  local skip_safety="false"
  if [ "${KAVEX_SKIP_SAFETY:-0}" = "1" ]; then
    skip_safety="true"
  elif [ -f "$config_file" ] && command -v jq &>/dev/null; then
    skip_safety=$(jq -r '.skip_safety // "false"' "$config_file" 2>/dev/null)
  fi
  if [ "$skip_safety" = "true" ]; then
    echo -e "  Safety:          ${RED}DISABLED${RESET} (kavex config --dangerously-skip-safety off to re-enable)"
  else
    echo -e "  Safety:          ${GREEN}active${RESET}"
  fi

  # Check jq
  if ! command -v jq &>/dev/null; then
    echo ""
    echo -e "  ${RED}WARNING: jq is not installed. Hooks require jq.${RESET}"
    echo "  Install: brew install jq (macOS) / apt install jq (Linux)"
  fi

  echo "═══════════════════════════════════════"
  echo ""
}

# ─────────────────────────────────────────────
# kavex activate
# ─────────────────────────────────────────────
cmd_activate() {
  if ! command -v jq &>/dev/null; then
    echo -e "${RED}Error: jq is required. Install: brew install jq${RESET}"
    exit 1
  fi

  # Ensure settings file exists
  if [ ! -f "$SETTINGS_LOCAL" ]; then
    if [ -f "$SETTINGS" ]; then
      cp "$SETTINGS" "$SETTINGS_LOCAL"
    else
      mkdir -p "$(dirname "$SETTINGS_LOCAL")"
      echo '{}' > "$SETTINGS_LOCAL"
    fi
  fi

  # Define hooks config — references scripts installed by install.sh into .claude/hooks/
  # Legacy install path; plugin mode uses hooks/hooks.json instead
  local hooks_json
  hooks_json=$(cat <<'HOOKS'
{
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {"type": "command", "command": "cat | .claude/hooks/block-dangerous.sh", "timeout": 5},
        {"type": "command", "command": "cat | .claude/hooks/kavex-commit-gate.sh", "timeout": 5}
      ]
    },
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [{"type": "command", "command": "cat | .claude/hooks/protect-files.sh", "timeout": 5}]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [{"type": "command", "command": "cat | .claude/hooks/format.sh", "timeout": 30}]
    }
  ],
  "Stop": [
    {
      "matcher": "",
      "hooks": [{"type": "command", "command": "cat | .claude/hooks/verify-on-stop.sh", "timeout": 60}]
    }
  ]
}
HOOKS
)

  # Merge hooks into settings (preserve everything else)
  local updated
  updated=$(jq --argjson hooks "$hooks_json" '.hooks = $hooks' "$SETTINGS_LOCAL")
  echo "$updated" > "$SETTINGS_LOCAL"

  echo ""
  echo -e "${BOLD}KAVEX ACTIVATED${RESET}"
  echo "═══════════════════════════════════════"
  echo -e "  ${GREEN}✓${RESET} block-dangerous   (PreToolUse)"
  echo -e "  ${GREEN}✓${RESET} protect-files     (PreToolUse)"
  echo -e "  ${GREEN}✓${RESET} format            (PostToolUse)"
  echo -e "  ${GREEN}✓${RESET} verify-on-stop    (Stop)"
  echo "═══════════════════════════════════════"
  echo ""
  echo "  Hooks take effect on NEXT Claude Code session."
  echo "  Run: kavex deactivate  to turn off."
  echo ""
}

# ─────────────────────────────────────────────
# kavex deactivate
# ─────────────────────────────────────────────
cmd_deactivate() {
  if ! command -v jq &>/dev/null; then
    echo -e "${RED}Error: jq is required. Install: brew install jq${RESET}"
    exit 1
  fi

  if [ ! -f "$SETTINGS_LOCAL" ]; then
    echo -e "${YELLOW}No settings.local.json found. Hooks are already inactive.${RESET}"
    exit 0
  fi

  # Remove hooks key, keep everything else
  local updated
  updated=$(jq 'del(.hooks)' "$SETTINGS_LOCAL")
  echo "$updated" > "$SETTINGS_LOCAL"

  echo ""
  echo -e "${BOLD}KAVEX DEACTIVATED${RESET}"
  echo "═══════════════════════════════════════"
  echo "  All automatic hooks disabled."
  echo ""
  echo "  Still available (on-demand):"
  echo "    /kavex:init         Scaffold a new PRD"
  echo "    /kavex:loop <prd>   Team Loop (6-phase cycle)"
  echo "    /verify-app        Manual verification"
  echo "    /plan              Plan before coding"
  echo "    /commit-push-pr    Commit workflow"
  echo "    /code-review       Code review"
  echo "    /fix-and-verify    Bug fix loop"
  echo "═══════════════════════════════════════"
  echo ""
  echo "  Run: kavex activate  to turn hooks back on."
  echo ""
}

# ─────────────────────────────────────────────
# kavex install
# ─────────────────────────────────────────────
cmd_install() {
  # Check if install.sh exists in kavex root or alongside this script
  if [ -f "$KAVEX_ROOT/install.sh" ]; then
    bash "$KAVEX_ROOT/install.sh" "$@"
  else
    cat <<'INSTALL'

  Install Kavex into a Project
  ═══════════════════════════════════════

  Option 1: Kavex Installer (recommended)
    cd /path/to/your/project
    bash /path/to/kavex/install.sh

  Preview first:
    bash /path/to/kavex/install.sh --dry-run

  Option 2: Copy .claude/ directory
    cp -r /path/to/kavex/.claude/ /your/project/.claude/

  Requirements:
    jq     — brew install jq / apt install jq
    gh     — brew install gh (optional, for PRs)
    codex  — npm install -g @openai/codex (optional, for multi-model review)

INSTALL
  fi
}

# ─────────────────────────────────────────────
# kavex setup (interactive wizard)
# ─────────────────────────────────────────────
cmd_setup() {
  echo ""
  echo -e "${BOLD}KAVEX SETUP WIZARD${RESET}"
  echo "═══════════════════════════════════════"
  echo ""

  # Step 1: Detect project stack
  echo -e "  ${CYAN}Step 1/4:${RESET} Detecting project stack..."
  local stack=""
  local pm="N/A"
  if [ -f "$PROJECT_ROOT/package.json" ]; then
    if [ -f "$PROJECT_ROOT/pnpm-lock.yaml" ]; then pm="pnpm"
    elif [ -f "$PROJECT_ROOT/yarn.lock" ]; then pm="yarn"
    elif [ -f "$PROJECT_ROOT/bun.lockb" ]; then pm="bun"
    else pm="npm"
    fi
    stack="${stack}Node.js ($pm), "
  fi
  [ -f "$PROJECT_ROOT/pyproject.toml" ] || [ -f "$PROJECT_ROOT/requirements.txt" ] && stack="${stack}Python, "
  [ -f "$PROJECT_ROOT/go.mod" ] && stack="${stack}Go, "
  [ -f "$PROJECT_ROOT/Cargo.toml" ] && stack="${stack}Rust, "
  [ -f "$PROJECT_ROOT/Gemfile" ] && stack="${stack}Ruby, "
  [ -f "$PROJECT_ROOT/pom.xml" ] || [ -f "$PROJECT_ROOT/build.gradle" ] && stack="${stack}Java, "
  ls "$PROJECT_ROOT"/*.csproj &>/dev/null 2>&1 || ls "$PROJECT_ROOT"/*.sln &>/dev/null 2>&1 && stack="${stack}.NET, "
  stack="${stack%, }"
  [ -z "$stack" ] && stack="none detected"
  echo -e "  Stack: ${GREEN}${stack}${RESET}"
  echo ""

  # Step 2: Install hooks
  echo -e "  ${CYAN}Step 2/4:${RESET} Installing hooks and commands..."
  cmd_install
  echo ""

  # Step 3: Activate hooks
  echo -e "  ${CYAN}Step 3/4:${RESET} Activating hooks..."
  cmd_activate
  echo ""

  # Step 4: Show status
  echo -e "  ${CYAN}Step 4/4:${RESET} Verifying setup..."
  cmd_status

  echo ""
  echo -e "${GREEN}Setup complete!${RESET} Start a Claude Code session to use Kavex."
  echo ""
}

# ─────────────────────────────────────────────
# kavex uninstall
# ─────────────────────────────────────────────
cmd_uninstall() {
  local proj_dir
  proj_dir="$(find_project_root)"

  echo ""
  echo -e "${BOLD}KAVEX UNINSTALL${RESET}"
  echo "═══════════════════════════════════════"
  echo "  Project: $proj_dir"
  echo ""

  # Remove hooks
  for hook in "${KAVEX_HOOK_FILES[@]}"; do
    if [ -f "$proj_dir/.claude/hooks/$hook" ]; then
      rm -f "$proj_dir/.claude/hooks/$hook"
      echo -e "  ${RED}✗${RESET} Removed hook: $hook"
    fi
  done

  # Remove Kavex-owned shared library files only
  if [ -d "$proj_dir/.claude/hooks/lib" ]; then
    local lib
    for lib in "${KAVEX_LIB_FILES[@]}"; do
      if [ -f "$proj_dir/.claude/hooks/lib/$lib" ]; then
        rm -f "$proj_dir/.claude/hooks/lib/$lib"
        echo -e "  ${RED}✗${RESET} Removed hooks/lib/$lib"
      fi
    done

    rmdir "$proj_dir/.claude/hooks/lib" 2>/dev/null && echo -e "  ${RED}✗${RESET} Removed empty hooks/lib/"
  fi

  # Remove empty hooks dir if nothing else remains
  rmdir "$proj_dir/.claude/hooks" 2>/dev/null && echo -e "  ${RED}✗${RESET} Removed empty hooks/"

  # Remove slash commands installed by Kavex
  for cmd_file in commit-push-pr.md verify-app.md daily-standup.md fix-and-verify.md code-review.md plan.md simplify.md; do
    rm -f "$proj_dir/.claude/commands/$cmd_file"
  done
  if [ -d "$proj_dir/.claude/commands/kavex" ]; then
    rm -rf "$proj_dir/.claude/commands/kavex"
    echo -e "  ${RED}✗${RESET} Removed commands/kavex/"
  fi
  echo -e "  ${RED}✗${RESET} Removed slash commands"

  # Remove CLI scripts
  rm -f "$proj_dir/.claude/kavex"
  rm -f "$proj_dir/.claude/kavex-monitor"
  echo -e "  ${RED}✗${RESET} Removed kavex and kavex-monitor CLIs"

  # Remove Kavex-managed hooks from settings.local.json, preserving user hooks
  if [ -f "$proj_dir/.claude/settings.local.json" ] && command -v jq &>/dev/null; then
    if remove_kavex_hooks_from_settings_file "$proj_dir/.claude/settings.local.json"; then
      echo -e "  ${RED}✗${RESET} Removed Kavex hooks from settings.local.json"
    fi
  fi

  # Restore settings.json from latest backup if available
  local latest_bak=""
  # shellcheck disable=SC2012
  latest_bak=$(ls -t "$proj_dir/.claude/settings.json.bak"* 2>/dev/null | head -1)
  if [ -n "$latest_bak" ]; then
    cp "$latest_bak" "$proj_dir/.claude/settings.json"
    echo -e "  ${GREEN}↺${RESET} Restored settings.json from backup"
  elif [ -f "$proj_dir/.claude/settings.json" ] && command -v jq &>/dev/null; then
    local is_kavex_managed="false"
    is_kavex_managed=$(is_kavex_managed_settings_file "$proj_dir/.claude/settings.json" || echo "false")

    if remove_kavex_hooks_from_settings_file "$proj_dir/.claude/settings.json"; then
      if [ "$is_kavex_managed" = "true" ]; then
        rm -f "$proj_dir/.claude/settings.json"
        echo -e "  ${RED}✗${RESET} Removed generated settings.json"
      else
        echo -e "  ${RED}✗${RESET} Removed Kavex hooks from settings.json"
      fi
    fi
  fi

  # Clean up loop state
  if [ -d "$proj_dir/.kavex-loop" ]; then
    rm -rf "$proj_dir/.kavex-loop"
    echo -e "  ${RED}✗${RESET} Removed .kavex-loop/ state directory"
  fi

  echo ""
  echo "═══════════════════════════════════════"
  echo "  Kavex uninstalled from $proj_dir"
  echo ""
  echo "  Files NOT removed (manual review):"
  echo "    CLAUDE.md / CLAUDE.kavex.md"
  echo "    .claude/settings.json (restored from backup if available)"
  echo "═══════════════════════════════════════"
  echo ""
}

# ─────────────────────────────────────────────
# kavex monitor (delegates to kavex-monitor)
# ─────────────────────────────────────────────
cmd_monitor() {
  local SCRIPT_DIR
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

  # Look for kavex-monitor in known locations
  local monitor_script=""
  if [ -f "$SCRIPT_DIR/kavex-monitor" ]; then
    monitor_script="$SCRIPT_DIR/kavex-monitor"
  elif [ -f "$PROJECT_ROOT/.claude/kavex-monitor" ]; then
    monitor_script="$PROJECT_ROOT/.claude/kavex-monitor"
  elif command -v kavex-monitor &>/dev/null; then
    monitor_script="kavex-monitor"
  fi

  if [ -z "$monitor_script" ]; then
    echo -e "${RED}Error: kavex-monitor not found.${RESET}" >&2
    echo "Run: kavex install  to install all components." >&2
    exit 1
  fi

  bash "$monitor_script" "$@"
}

# ─────────────────────────────────────────────
# kavex config
# ─────────────────────────────────────────────
KAVEX_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/kavex"
KAVEX_CONFIG_FILE="$KAVEX_CONFIG_DIR/config.json"

_ensure_config() {
  if [ ! -f "$KAVEX_CONFIG_FILE" ]; then
    mkdir -p "$KAVEX_CONFIG_DIR"
    echo '{}' > "$KAVEX_CONFIG_FILE"
  fi
}

_get_config() {
  local key="$1"
  local default="${2:-}"
  _ensure_config
  local val
  val=$(jq -r ".$key // empty" "$KAVEX_CONFIG_FILE" 2>/dev/null)
  echo "${val:-$default}"
}

_set_config() {
  local key="$1" val="$2"
  _ensure_config
  local updated
  updated=$(jq --arg v "$val" ".$key = \$v" "$KAVEX_CONFIG_FILE")
  printf '%s\n' "$updated" > "$KAVEX_CONFIG_FILE"
}

cmd_config() {
  if ! command -v jq &>/dev/null; then
    echo -e "${RED}Error: jq is required. Install: brew install jq${RESET}"
    exit 1
  fi

  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    --dangerously-skip-safety)
      local action="${1:-}"
      case "$action" in
        on|true|1)
          _set_config "skip_safety" "true"
          echo ""
          echo -e "${RED}${BOLD}  WARNING: Safety hooks disabled.${RESET}"
          echo -e "${RED}  ─────────────────────────────────────────────${RESET}"
          echo -e "  block-dangerous.sh   ${RED}DISABLED${RESET}"
          echo -e "  protect-files.sh     ${RED}DISABLED${RESET}"
          echo -e "  kavex-commit-gate.sh ${RED}DISABLED${RESET}"
          echo ""
          echo -e "  Kavex will ${RED}NOT${RESET} block dangerous commands or"
          echo -e "  protect sensitive files until you re-enable safety."
          echo ""
          echo -e "  Re-enable: ${CYAN}kavex config --dangerously-skip-safety off${RESET}"
          echo ""
          echo -e "  ${YELLOW}To apply: restart your Claude Code session.${RESET}"
          echo ""
          ;;
        off|false|0)
          _set_config "skip_safety" "false"
          echo ""
          echo -e "${GREEN}${BOLD}  Safety hooks re-enabled.${RESET}"
          echo -e "  ─────────────────────────────────────────────"
          echo -e "  block-dangerous.sh   ${GREEN}ACTIVE${RESET}"
          echo -e "  protect-files.sh     ${GREEN}ACTIVE${RESET}"
          echo -e "  kavex-commit-gate.sh ${GREEN}ACTIVE${RESET}"
          echo ""
          echo -e "  ${YELLOW}To apply: restart your Claude Code session.${RESET}"
          echo ""
          ;;
        "")
          local current
          current=$(_get_config "skip_safety" "false")
          if [ "$current" = "true" ]; then
            echo -e "  skip_safety: ${RED}true${RESET} (safety hooks disabled)"
          else
            echo -e "  skip_safety: ${GREEN}false${RESET} (safety hooks active)"
          fi
          ;;
        *)
          echo -e "${RED}Usage: kavex config --dangerously-skip-safety [on|off]${RESET}"
          exit 1
          ;;
      esac
      ;;
    ""|--show)
      _ensure_config
      echo ""
      echo -e "${BOLD}KAVEX CONFIG${RESET}"
      echo "═══════════════════════════════════════"
      echo -e "  Config file: ${DIM}$KAVEX_CONFIG_FILE${RESET}"
      echo ""

      local skip_safety
      skip_safety=$(_get_config "skip_safety" "false")
      if [ "$skip_safety" = "true" ]; then
        echo -e "  skip_safety:  ${RED}true${RESET} (safety hooks disabled)"
      else
        echo -e "  skip_safety:  ${GREEN}false${RESET} (safety hooks active)"
      fi

      echo ""
      echo "═══════════════════════════════════════"
      echo ""
      echo "  Available config options:"
      echo "    kavex config --dangerously-skip-safety [on|off]"
      echo ""
      ;;
    *)
      echo -e "${RED}Unknown config option: $subcmd${RESET}"
      echo ""
      echo "  Available config options:"
      echo "    kavex config --dangerously-skip-safety [on|off]"
      echo ""
      exit 1
      ;;
  esac
}

# ─────────────────────────────────────────────
# Main dispatch
# ─────────────────────────────────────────────
case "${1:-}" in
  help|-h|--help|"")
    cmd_help
    ;;
  status)
    cmd_status
    ;;
  activate)
    cmd_activate
    ;;
  deactivate)
    cmd_deactivate
    ;;
  install)
    shift
    cmd_install "$@"
    ;;
  setup)
    cmd_setup
    ;;
  monitor)
    shift
    cmd_monitor "$@"
    ;;
  uninstall)
    cmd_uninstall
    ;;
  config)
    shift
    cmd_config "$@"
    ;;
  *)
    echo -e "${RED}Unknown command: $1${RESET}"
    echo ""
    echo "Usage: kavex <command>"
    echo ""
    echo "Commands:"
    echo "  help        Show help"
    echo "  status      Check setup"
    echo "  activate    Turn ON hooks"
    echo "  deactivate  Turn OFF hooks"
    echo "  install     Install into project"
    echo "  uninstall   Remove Kavex from project"
    echo "  setup       Interactive setup wizard"
    echo "  monitor     tmux dashboard"
    echo "  config      Manage Kavex configuration"
    echo ""
    echo "For LLM-powered commands, use Claude Code:"
    echo "  /kavex:init [name]   Scaffold a PRD"
    echo "  /kavex:loop <prd>    Run the Team Loop"
    exit 1
    ;;
esac
